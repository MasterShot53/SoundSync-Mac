<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shapes="clr-namespace:Avalonia.Controls.Shapes;assembly=Avalonia.Controls"
        xmlns:views="clr-namespace:SoundSync.Mac.Views"
        x:Class="SoundSync.Mac.MainWindow"
        Title="SoundSync" Width="1200" Height="840"
        MinWidth="860" MinHeight="600"
        Background="#07080E">

    <Grid ColumnDefinitions="220,*">

        <!-- ── Background gradient blobs (5 total, matching Windows) ── -->
        <Panel Grid.ColumnSpan="2" IsHitTestVisible="False">
            <Rectangle Fill="#07080E"/>
            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush Center="22%,28%" GradientOrigin="22%,28%" Radius="0.9">
                        <GradientStop Color="#0F1E55" Offset="0"/>
                        <GradientStop Color="#0007080E" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush Center="78%,55%" GradientOrigin="78%,55%" Radius="0.8">
                        <GradientStop Color="#0D1B4A" Offset="0"/>
                        <GradientStop Color="#0007080E" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush Center="42%,82%" GradientOrigin="42%,82%" Radius="0.72">
                        <GradientStop Color="#0B1840" Offset="0"/>
                        <GradientStop Color="#0007080E" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush Center="8%,72%" GradientOrigin="8%,72%" Radius="0.6">
                        <GradientStop Color="#091228" Offset="0"/>
                        <GradientStop Color="#0007080E" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush Center="88%,18%" GradientOrigin="88%,18%" Radius="0.55">
                        <GradientStop Color="#080E2A" Offset="0"/>
                        <GradientStop Color="#0007080E" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Panel>

        <!-- ══════════════════════════════════════
             LEFT SIDEBAR
        ══════════════════════════════════════ -->
        <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="#1F2230"
                Background="#EE111111">
            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">

                <!-- Sidebar gradient blobs -->
                <Panel Grid.RowSpan="6" IsHitTestVisible="False">
                    <Rectangle>
                        <Rectangle.Fill>
                            <RadialGradientBrush Center="-30%,-20%" GradientOrigin="-30%,-20%" Radius="1.1">
                                <GradientStop Color="#0C1535" Offset="0"/>
                                <GradientStop Color="#00111111" Offset="1"/>
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle>
                        <Rectangle.Fill>
                            <RadialGradientBrush Center="120%,130%" GradientOrigin="120%,130%" Radius="1.1">
                                <GradientStop Color="#091228" Offset="0"/>
                                <GradientStop Color="#00111111" Offset="1"/>
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Panel>

                <!-- Row 0 — Logo (left padding leaves room for macOS traffic lights) -->
                <Border Grid.Row="0" Padding="16,18,16,12">
                    <StackPanel Orientation="Horizontal" Spacing="9">
                        <Viewbox Width="22" Height="22" VerticalAlignment="Center">
                            <Canvas Width="24" Height="20">
                                <shapes:Path Stroke="#9B7FFF" StrokeThickness="2"
                                             StrokeLineCap="Round" StrokeJoin="Round"
                                             Data="M2,10 Q4,4 6,10 Q8,16 10,10 Q12,4 14,10 Q16,16 18,10 Q20,4 22,10"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="SoundSync" FontSize="17" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Row 1 — Nav buttons -->
                <StackPanel Grid.Row="1" Margin="0,4,0,0">
                    <Button x:Name="NavDevices" Classes="NavBtn Active" Click="NavDevices_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⊞" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Devices" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavSync" Classes="NavBtn" Click="NavSync_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="◈" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Sync" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavSettings" Classes="NavBtn" Click="NavSettings_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Row 2 — Quick Actions -->
                <StackPanel Grid.Row="2" Margin="10,10,10,4" Spacing="6">
                    <TextBlock Text="QUICK ACTIONS" FontSize="9" FontWeight="SemiBold"
                               Foreground="#4B4F6B" Margin="4,0,0,0"/>
                    <Grid ColumnDefinitions="*,6,*">
                        <Button x:Name="BtnQaBeat" Grid.Column="0" Classes="Secondary"
                                Content="Play Beat" FontSize="11" Padding="0,7"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Click="BtnQaBeat_Click"/>
                        <Button x:Name="BtnQaMute" Grid.Column="2" Classes="Secondary"
                                Content="Mute All" FontSize="11" Padding="0,7"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Click="BtnQaMute_Click"/>
                    </Grid>
                </StackPanel>

                <!-- Row 3 — Spacer -->
                <Panel Grid.Row="3"/>

                <!-- Row 4 — Master Volume card -->
                <Border Grid.Row="4" Margin="10,0,10,10" Padding="14,13" Classes="Card">
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="MASTER VOLUME" FontSize="9" FontWeight="SemiBold"
                                       Foreground="#4B4F6B"/>
                            <TextBlock x:Name="SidebarVolLabel" Grid.Column="1"
                                       Text="100%" FontSize="11" Foreground="#8B8FA8"/>
                        </Grid>
                        <Slider x:Name="SidebarVolumeSlider" Minimum="0" Maximum="100" Value="100"
                                TickFrequency="1"
                                ValueChanged="SidebarVolumeSlider_Changed"/>
                    </StackPanel>
                </Border>

                <!-- Row 5 — Engine card -->
                <Border Grid.Row="5" Margin="10,0,10,16" Padding="14,16" Classes="AccentCard">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,2">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8"
                                     Fill="#4B4F6B" VerticalAlignment="Center"/>
                            <TextBlock Text="ENGINE" FontSize="9" FontWeight="SemiBold"
                                       Foreground="#4B4F6B"/>
                        </StackPanel>
                        <TextBlock x:Name="SidebarStatusText" Text="Stopped"
                                   FontSize="15" FontWeight="SemiBold" Foreground="#8B8FA8"/>
                        <TextBlock x:Name="SidebarSourceName" Text="No Source"
                                   FontSize="11" Foreground="#4B4F6B" IsVisible="False"/>
                        <TextBlock x:Name="SidebarSampleRate" Text=""
                                   FontSize="11" Foreground="#4B4F6B" IsVisible="False"/>
                        <Button x:Name="SidebarEngineBtn" Classes="Primary"
                                Margin="0,10,0,0" HorizontalAlignment="Stretch"
                                Click="SidebarEngineBtn_Click">
                            <TextBlock x:Name="SidebarEngineBtnText" Text="Start Engine"
                                       FontSize="13" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             CONTENT AREA
        ══════════════════════════════════════ -->
        <Panel Grid.Column="1">
            <views:DevicesView  x:Name="PageDevices"/>
            <views:SyncView     x:Name="PageSync"     IsVisible="False"/>
            <views:SettingsView x:Name="PageSettings" IsVisible="False"/>
        </Panel>

    </Grid>
</Window>
