<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shapes="clr-namespace:Avalonia.Controls.Shapes;assembly=Avalonia.Controls"
        xmlns:views="clr-namespace:SoundSync.Mac.Views"
        xmlns:controls="clr-namespace:SoundSync.Mac.Controls"
        x:Class="SoundSync.Mac.MainWindow"
        Title="SoundSync" Width="1200" Height="840"
        MinWidth="860" MinHeight="600"
        Background="#07080E">
    <Window.Icon>
        <WindowIcon>avares://SoundSync/Assets/AppIcon.png</WindowIcon>
    </Window.Icon>

    <Grid ColumnDefinitions="220,*">

        <!-- ── Background gradient blobs (5 total, exact Windows positions) ── -->
        <Panel Grid.ColumnSpan="2" IsHitTestVisible="False">
            <Rectangle Fill="#07080E"/>
            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush Center="22%,28%" GradientOrigin="22%,28%" Radius="0.9">
                        <GradientStop Color="#0F1E55" Offset="0"/>
                        <GradientStop Color="#0007080E" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush Center="78%,55%" GradientOrigin="78%,55%" Radius="0.8">
                        <GradientStop Color="#0D1B4A" Offset="0"/>
                        <GradientStop Color="#0007080E" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush Center="42%,82%" GradientOrigin="42%,82%" Radius="0.72">
                        <GradientStop Color="#0B1840" Offset="0"/>
                        <GradientStop Color="#0007080E" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush Center="62%,18%" GradientOrigin="62%,18%" Radius="0.70">
                        <GradientStop Color="#202020" Offset="0"/>
                        <GradientStop Color="#0007080E" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush Center="14%,70%" GradientOrigin="14%,70%" Radius="0.74">
                        <GradientStop Color="#1C1C1C" Offset="0"/>
                        <GradientStop Color="#0007080E" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Panel>

        <!-- ══════════════════════════════════════
             LEFT SIDEBAR
        ══════════════════════════════════════ -->
        <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="#1F2230"
                Background="#EE111111">
            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <!-- Sidebar gradient blobs -->
                <Panel Grid.RowSpan="4" IsHitTestVisible="False">
                    <Rectangle>
                        <Rectangle.Fill>
                            <RadialGradientBrush Center="-30%,-20%" GradientOrigin="-30%,-20%" Radius="1.1">
                                <GradientStop Color="#0C1535" Offset="0"/>
                                <GradientStop Color="#00111111" Offset="1"/>
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle>
                        <Rectangle.Fill>
                            <RadialGradientBrush Center="120%,130%" GradientOrigin="120%,130%" Radius="1.1">
                                <GradientStop Color="#091228" Offset="0"/>
                                <GradientStop Color="#00111111" Offset="1"/>
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Panel>

                <!-- Row 0 — Logo -->
                <Border Grid.Row="0" Padding="16,20,16,10">
                    <StackPanel Orientation="Horizontal" Spacing="9">
                        <Viewbox Width="22" Height="22" VerticalAlignment="Center">
                            <Canvas Width="24" Height="20">
                                <Rectangle Canvas.Left="2.5"  Canvas.Top="5.5" Width="3" Height="9"  RadiusX="1.5" RadiusY="1.5" Fill="#8C64FF"/>
                                <Rectangle Canvas.Left="6.5"  Canvas.Top="3"   Width="3" Height="14" RadiusX="1.5" RadiusY="1.5" Fill="#7370FF"/>
                                <Rectangle Canvas.Left="10.5" Canvas.Top="1"   Width="3" Height="18" RadiusX="1.5" RadiusY="1.5" Fill="#5A7CFF"/>
                                <Rectangle Canvas.Left="14.5" Canvas.Top="3"   Width="3" Height="14" RadiusX="1.5" RadiusY="1.5" Fill="#4188FF"/>
                                <Rectangle Canvas.Left="18.5" Canvas.Top="5.5" Width="3" Height="9"  RadiusX="1.5" RadiusY="1.5" Fill="#286EFF"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="SoundSync" FontSize="17" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Row 1 — Nav buttons -->
                <StackPanel Grid.Row="1" Margin="0,6,0,0">
                    <Button x:Name="NavDevices" Classes="NavBtn Active" Click="NavDevices_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⊞" FontSize="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Devices" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavSpatial" Classes="NavBtn" Click="NavSpatial_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="◎" FontSize="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Spatial" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavSettings" Classes="NavBtn" Click="NavSettings_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⚙" FontSize="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Row 2 — Volume card + Quick Actions, pushed to bottom of the grid row -->
                <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="10,16,10,10">

                        <!-- Master Volume card (AccentCard gradient matching Windows) -->
                        <Border CornerRadius="14" BorderThickness="1" Padding="14,14" Margin="0,0,0,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#1A2440" Offset="0"/>
                                    <GradientStop Color="#141820" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#604F7CFF" Offset="0"/>
                                    <GradientStop Color="#12FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <StackPanel>
                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,10">
                                    <TextBlock Grid.Column="0" Text="♪" FontSize="13"
                                               Foreground="#2266FF"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="MASTER VOLUME"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#4B4F6B"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SidebarVolLabel" Grid.Column="2" Text="100%"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="#2266FF"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <controls:SyncSlider x:Name="SidebarVolumeSlider"
                                        Minimum="0" Maximum="100" Value="100"
                                        TickFrequency="1"
                                        ResetValue="100"
                                        ValueChanged="SidebarVolumeSlider_Changed"/>
                            </StackPanel>
                        </Border>

                        <!-- Quick Actions label -->
                        <TextBlock Text="QUICK ACTIONS"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#4B4F6B"
                                   Margin="2,0,0,8"/>

                        <!-- 3 full-width vertical pill buttons -->
                        <StackPanel Spacing="6" Margin="0,0,0,4">

                            <!-- Play Beat -->
                            <Button x:Name="BtnQaBeat" Classes="PillActionBtn" Click="BtnQaBeat_Click">
                                <Border CornerRadius="12" BorderThickness="1" Padding="12,0" Height="42">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                            <GradientStop Color="#1C2035" Offset="0"/>
                                            <GradientStop Color="#141828" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                            <GradientStop Color="#28FFFFFF" Offset="0"/>
                                            <GradientStop Color="#08FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                        <TextBlock Text="♩" FontSize="13"
                                                   Foreground="#2266FF" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="SidebarBeatBtnText" Text="Play Beat"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Button>

                            <!-- Mute All -->
                            <Button x:Name="BtnQaMute" Classes="PillActionBtn" Click="BtnQaMute_Click">
                                <Border CornerRadius="12" BorderThickness="1" Padding="12,0" Height="42">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                            <GradientStop Color="#1C2035" Offset="0"/>
                                            <GradientStop Color="#141828" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                            <GradientStop Color="#28FFFFFF" Offset="0"/>
                                            <GradientStop Color="#08FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                        <TextBlock x:Name="MuteIcon" Text="⊘" FontSize="13"
                                                   Foreground="#2266FF" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="SidebarMuteBtnText" Text="Mute All"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Button>

                            <!-- Test Channel -->
                            <Button x:Name="BtnQaTest" Classes="PillActionBtn" Click="BtnQaTest_Click">
                                <Border CornerRadius="12" BorderThickness="1" Padding="12,0" Height="42">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                            <GradientStop Color="#1C2035" Offset="0"/>
                                            <GradientStop Color="#141828" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                            <GradientStop Color="#28FFFFFF" Offset="0"/>
                                            <GradientStop Color="#08FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                        <TextBlock Text="▶" FontSize="13"
                                                   Foreground="#2266FF" VerticalAlignment="Center"/>
                                        <TextBlock Text="Test Channel"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Button>

                        </StackPanel>
                    </StackPanel>

                <!-- Row 3 — Engine card (regular Card colors, NOT accent) -->
                <Border Grid.Row="3" Margin="10,6,10,14" Padding="14,18" CornerRadius="12" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Color="#1E2230" Offset="0"/>
                            <GradientStop Color="#141820" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Color="#28FFFFFF" Offset="0"/>
                            <GradientStop Color="#06FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8"
                                     Fill="#4B4F6B" VerticalAlignment="Center"/>
                            <TextBlock Text="Engine" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#8B8FA8"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="SidebarStatusText" Text="Stopped"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#8B8FA8" Margin="0,0,0,2"/>
                        <TextBlock x:Name="SidebarSourceName" Text=""
                                   FontSize="11" Foreground="#4B4F6B" IsVisible="False"/>
                        <TextBlock x:Name="SidebarSampleRate" Text=""
                                   FontSize="11" Foreground="#4B4F6B" IsVisible="False" Margin="0,1,0,0"/>
                        <Button x:Name="SidebarEngineBtn" Margin="0,14,0,0"
                                HorizontalAlignment="Stretch"
                                Click="SidebarEngineBtn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="EngineBtnBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="10" Height="48">
                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                                          HorizontalContentAlignment="Center"
                                                          VerticalContentAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock x:Name="SidebarEngineBtnText" Text="Start Engine"
                                       FontSize="13" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             CONTENT AREA
        ══════════════════════════════════════ -->
        <Panel Grid.Column="1">
            <views:DevicesView  x:Name="PageDevices"/>
            <views:SpatialView  x:Name="PageSpatial"  IsVisible="False"/>
            <views:SettingsView x:Name="PageSettings" IsVisible="False"/>
        </Panel>

        <!-- ── In-app toast (floats over content area) ── -->
        <Border x:Name="ToastCard"
                Grid.Column="1"
                ZIndex="100"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,28"
                MaxWidth="500" MinWidth="280"
                CornerRadius="12"
                BorderThickness="1"
                IsVisible="False"
                BoxShadow="0 6 24 0 #80FF453A">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#F0201828" Offset="0"/>
                    <GradientStop Color="#F0181420" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#80FF453A" Offset="0"/>
                    <GradientStop Color="#20FF453A" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Grid Margin="16,13,12,13" ColumnDefinitions="Auto,*,Auto">
                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8"
                        Background="#40FF453A" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="!" FontSize="16" FontWeight="Bold"
                               Foreground="#FF453A"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="ToastMessage" Grid.Column="1"
                           FontSize="13" FontWeight="Medium"
                           Foreground="White" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="2" Width="28" Height="28"
                        Background="Transparent" BorderThickness="0"
                        Margin="10,0,0,0" Cursor="Hand"
                        Click="ToastClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="×" FontSize="14" Foreground="#99FFFFFF"/>
                </Button>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             TEST CHANNEL MODAL
        ══════════════════════════════════════ -->
        <Grid x:Name="TestChannelOverlay" Grid.ColumnSpan="2" ZIndex="60" IsVisible="False">
            <!-- Backdrop -->
            <Border Background="#C0000000" PointerPressed="TestChannelBackdrop_Click"/>
            <!-- Modal card -->
            <Border Width="360" CornerRadius="20" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="28,26"
                    BoxShadow="0 0 50 0 #A5000814">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#1E2230" Offset="0"/>
                        <GradientStop Color="#141820" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#28FFFFFF" Offset="0"/>
                        <GradientStop Color="#06FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <!-- Inner border stops backdrop from closing when clicking inside card -->
                <Border PointerPressed="TestChannelCard_Click">
                    <StackPanel>
                        <!-- Header -->
                        <Grid Margin="0,0,0,6" ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="TEST CHANNEL"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#4B4F6B" Margin="0,0,0,5"/>
                                <TextBlock Text="Play a test tone"
                                           FontSize="19" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <Button Grid.Column="1" Width="30" Height="30"
                                    VerticalAlignment="Top" Classes="Secondary" Padding="0"
                                    Click="TestChannelClose_Click">
                                <TextBlock Text="×" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </Grid>

                        <TextBlock Text="Select a channel to play a 1000 Hz tone through all speakers."
                                   FontSize="13" Foreground="#8B8FA8"
                                   TextWrapping="Wrap" Margin="0,8,0,26"/>

                        <!-- L / C / R channel buttons -->
                        <Grid ColumnDefinitions="*,10,*,10,*">

                            <!-- L — blue -->
                            <Border x:Name="TestChannelLBtn" Grid.Column="0" Height="84" CornerRadius="14" BorderThickness="1"
                                    Cursor="Hand" PointerPressed="TestChannelL_Click">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                        <GradientStop Color="#1A2440" Offset="0"/>
                                        <GradientStop Color="#141820" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                        <GradientStop Color="#604F7CFF" Offset="0"/>
                                        <GradientStop Color="#12FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                    <TextBlock Text="◁" FontSize="22" Foreground="#4F7CFF"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="LEFT" FontSize="12" FontWeight="Bold"
                                               Foreground="#4F7CFF" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- C — gray -->
                            <Border x:Name="TestChannelCBtn" Grid.Column="2" Height="84" CornerRadius="14" BorderThickness="1"
                                    Cursor="Hand" PointerPressed="TestChannelC_Click">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                        <GradientStop Color="#1E2230" Offset="0"/>
                                        <GradientStop Color="#141820" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                        <GradientStop Color="#28FFFFFF" Offset="0"/>
                                        <GradientStop Color="#06FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                    <TextBlock Text="◎" FontSize="22" Foreground="#8B8FA8"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="CENTER" FontSize="12" FontWeight="Bold"
                                               Foreground="#8B8FA8" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- R — purple -->
                            <Border x:Name="TestChannelRBtn" Grid.Column="4" Height="84" CornerRadius="14" BorderThickness="1"
                                    Cursor="Hand" PointerPressed="TestChannelR_Click">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                        <GradientStop Color="#1A1040" Offset="0"/>
                                        <GradientStop Color="#141820" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                        <GradientStop Color="#604F7CFF" Offset="0"/>
                                        <GradientStop Color="#12FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                    <TextBlock Text="▷" FontSize="22" Foreground="#9B7FFF"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="RIGHT" FontSize="12" FontWeight="Bold"
                                               Foreground="#9B7FFF" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                        </Grid>

                        <TextBlock x:Name="TestChannelStatus"
                                   Text=""
                                   FontSize="12" Foreground="#8B8FA8"
                                   HorizontalAlignment="Center"
                                   Margin="0,18,0,0"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

        <!-- BlackHole install overlay -->
        <Grid x:Name="BlackHoleOverlay" Grid.ColumnSpan="2" ZIndex="60" IsVisible="False">
            <Border Background="#C0000000" PointerPressed="BlackHoleBackdrop_Click"/>
            <Border Width="380" CornerRadius="20" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="28,26" BoxShadow="0 0 50 0 #A5000814">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#1E2230" Offset="0"/>
                        <GradientStop Color="#141820" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#28FFFFFF" Offset="0"/>
                        <GradientStop Color="#06FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border PointerPressed="BlackHoleCard_Click">
                    <StackPanel Spacing="0">
                        <Grid Margin="0,0,0,6" ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="AUDIO DRIVER" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#4B4F6B" Margin="0,0,0,5"/>
                                <TextBlock Text="Install BlackHole" FontSize="19" FontWeight="Bold"
                                           Foreground="White"/>
                            </StackPanel>
                            <Button Grid.Column="1" Width="30" Height="30"
                                    VerticalAlignment="Top" Classes="Secondary" Padding="0"
                                    Click="BlackHoleClose_Click">
                                <TextBlock Text="×" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </Grid>

                        <TextBlock Text="SoundSync needs BlackHole, a free virtual audio driver, to route audio between your speakers. Installation requires your Mac password once."
                                   FontSize="13" Foreground="#8B8FA8"
                                   TextWrapping="Wrap" Margin="0,10,0,24"/>

                        <!-- Status / progress -->
                        <Border x:Name="BlackHoleProgressRow" IsVisible="False" Margin="0,0,0,16">
                            <StackPanel Spacing="8">
                                <TextBlock x:Name="BlackHoleProgressText" FontSize="13"
                                           Foreground="#8B8FA8" TextWrapping="Wrap"/>
                                <ProgressBar IsIndeterminate="True" Height="3"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="BtnInstallBlackHole"
                                HorizontalAlignment="Stretch"
                                Height="42" CornerRadius="10"
                                Click="BtnInstallBlackHole_Click">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                    <GradientStop Color="#7B5FFF" Offset="0"/>
                                    <GradientStop Color="#2266FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <TextBlock Text="Install BlackHole (Free)"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

    </Grid>
</Window>
