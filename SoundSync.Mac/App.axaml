             x:Class="SoundSync.Mac.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme/>
        <StyleInclude Source="avares://SoundSync/Styles/Themes.axaml"/>
    </Application.Styles>
</Application>
