<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SoundSync.Mac.Controls;assembly=SoundSync">

    <Styles.Resources>

        <!-- ── Color palette ── -->
        <Color x:Key="ColorBg">#0F1115</Color>
        <Color x:Key="ColorSidebar">#111111</Color>
        <Color x:Key="ColorSurface">#1A1D24</Color>
        <Color x:Key="ColorElevated">#252A35</Color>
        <Color x:Key="ColorAccent">#2266FF</Color>
        <Color x:Key="ColorAccentSubtle">#0D1B45</Color>
        <Color x:Key="ColorGreen">#3DDC84</Color>
        <Color x:Key="ColorWarning">#FFB020</Color>
        <Color x:Key="ColorRed">#FF453A</Color>
        <Color x:Key="ColorText">#FFFFFFFF</Color>
        <Color x:Key="ColorTextSecondary">#8B8FA8</Color>
        <Color x:Key="ColorTextTertiary">#4B4F6B</Color>
        <Color x:Key="ColorSeparator">#1F2230</Color>
        <Color x:Key="ColorPurple">#9B7FFF</Color>
        <Color x:Key="ColorCardTop">#1E2230</Color>
        <Color x:Key="ColorCardBottom">#141820</Color>
        <Color x:Key="ColorCardBorderTop">#28FFFFFF</Color>
        <Color x:Key="ColorCardBorderBottom">#06FFFFFF</Color>
        <Color x:Key="ColorSyncCardTop">#1A2440</Color>
        <Color x:Key="ColorSyncCardBottom">#141820</Color>
        <Color x:Key="ColorSyncCardBorderTop">#604F7CFF</Color>
        <Color x:Key="ColorSyncCardBorderBottom">#12FFFFFF</Color>
        <Color x:Key="ColorSyncSeparator">#404F7CFF</Color>
        <Color x:Key="ColorPillTop">#1C2035</Color>
        <Color x:Key="ColorPillBottom">#141828</Color>
        <Color x:Key="ColorPillBorderTop">#28FFFFFF</Color>
        <Color x:Key="ColorPillBorderBottom">#08FFFFFF</Color>
        <Color x:Key="ColorEmptyTop">#1A1D26</Color>
        <Color x:Key="ColorEmptyBottom">#131620</Color>
        <Color x:Key="ColorDestructiveBg">#3A1A1A</Color>
        <Color x:Key="ColorDestructiveBorder">#5A2020</Color>

        <!-- ── Solid brushes ── -->
        <SolidColorBrush x:Key="BrushBg"              Color="{StaticResource ColorBg}"/>
        <SolidColorBrush x:Key="BrushSurface"         Color="{StaticResource ColorSurface}"/>
        <SolidColorBrush x:Key="BrushElevated"        Color="{StaticResource ColorElevated}"/>
        <SolidColorBrush x:Key="BrushAccent"          Color="{StaticResource ColorAccent}"/>
        <SolidColorBrush x:Key="BrushAccentSubtle"    Color="{StaticResource ColorAccentSubtle}"/>
        <SolidColorBrush x:Key="BrushGreen"           Color="{StaticResource ColorGreen}"/>
        <SolidColorBrush x:Key="BrushRed"             Color="{StaticResource ColorRed}"/>
        <SolidColorBrush x:Key="BrushText"            Color="{StaticResource ColorText}"/>
        <SolidColorBrush x:Key="BrushTextSecondary"   Color="{StaticResource ColorTextSecondary}"/>
        <SolidColorBrush x:Key="BrushTextTertiary"    Color="{StaticResource ColorTextTertiary}"/>
        <SolidColorBrush x:Key="BrushSeparator"       Color="{StaticResource ColorSeparator}"/>
        <SolidColorBrush x:Key="BrushPurple"          Color="{StaticResource ColorPurple}"/>
        <SolidColorBrush x:Key="BrushDestructiveBg"   Color="{StaticResource ColorDestructiveBg}"/>
        <SolidColorBrush x:Key="BrushDestructiveBorder" Color="{StaticResource ColorDestructiveBorder}"/>

        <!-- ── Gradient brushes ── -->
        <LinearGradientBrush x:Key="BrushCardBg" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="{StaticResource ColorCardTop}"    Offset="0"/>
            <GradientStop Color="{StaticResource ColorCardBottom}" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BrushCardBorder" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="{StaticResource ColorCardBorderTop}"    Offset="0"/>
            <GradientStop Color="{StaticResource ColorCardBorderBottom}" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BrushAccentCardBg" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="{StaticResource ColorSyncCardTop}"    Offset="0"/>
            <GradientStop Color="{StaticResource ColorSyncCardBottom}" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BrushAccentCardBorder" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="{StaticResource ColorSyncCardBorderTop}"    Offset="0"/>
            <GradientStop Color="{StaticResource ColorSyncCardBorderBottom}" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BrushAccentBtn" StartPoint="0%,0%" EndPoint="100%,0%">
            <GradientStop Color="#2266FF" Offset="0"/>
            <GradientStop Color="#1A55EE" Offset="1"/>
        </LinearGradientBrush>

        <!-- ── Corner radii ── -->
        <CornerRadius x:Key="RadiusCard">14</CornerRadius>
        <CornerRadius x:Key="RadiusButton">10</CornerRadius>
        <CornerRadius x:Key="RadiusPill">22</CornerRadius>
        <CornerRadius x:Key="RadiusSmall">8</CornerRadius>

    </Styles.Resources>

    <!-- ── Global TextBlock foreground ── -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
    </Style>

    <!-- ── ToggleSwitch: strip On/Off text labels so only the knob shows ── -->
    <Style Selector="ToggleSwitch">
        <Setter Property="OffContent" Value=""/>
        <Setter Property="OnContent"  Value=""/>
        <Setter Property="Margin"     Value="0"/>
    </Style>

    <!-- ═══════════════════════════════════════════════
         PRIMARY BUTTON
         Height=38, gradient bg, scale 1.04 hover / 0.95 press + glow
    ═══════════════════════════════════════════════ -->
    <Style Selector="Button.Primary">
        <Setter Property="Foreground"            Value="White"/>
        <Setter Property="FontSize"              Value="13"/>
        <Setter Property="FontWeight"            Value="SemiBold"/>
        <Setter Property="Padding"               Value="16,9"/>
        <Setter Property="Height"                Value="38"/>
        <Setter Property="BorderThickness"       Value="0"/>
        <Setter Property="Background"            Value="{StaticResource BrushAccentBtn}"/>
        <Setter Property="Cursor"                Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        <Setter Property="RenderTransform"       Value="scale(1)"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border x:Name="Root"
                        Background="{TemplateBinding Background}"
                        CornerRadius="10"
                        Padding="{TemplateBinding Padding}"
                        Height="{TemplateBinding Height}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.Primary:pointerover">
        <Setter Property="RenderTransform" Value="scale(1.04)"/>
    </Style>
    <Style Selector="Button.Primary:pointerover /template/ Border#Root">
        <Setter Property="BoxShadow" Value="0 0 14 0 #722266FF"/>
    </Style>
    <Style Selector="Button.Primary:pressed">
        <Setter Property="RenderTransform" Value="scale(0.95)"/>
    </Style>
    <Style Selector="Button.Primary:pressed /template/ Border#Root">
        <Setter Property="Opacity" Value="0.72"/>
    </Style>
    <Style Selector="Button.Primary:disabled /template/ Border#Root">
        <Setter Property="Opacity" Value="0.40"/>
    </Style>

    <!-- ═══════════════════════════════════════════════
         SECONDARY BUTTON
         Height=38, elevated bg, scale 1.04 hover / 0.95 press
    ═══════════════════════════════════════════════ -->
    <Style Selector="Button.Secondary">
        <Setter Property="Background"            Value="{StaticResource BrushElevated}"/>
        <Setter Property="Foreground"            Value="{StaticResource BrushText}"/>
        <Setter Property="FontSize"              Value="13"/>
        <Setter Property="FontWeight"            Value="Medium"/>
        <Setter Property="Padding"               Value="16,9"/>
        <Setter Property="Height"                Value="38"/>
        <Setter Property="BorderThickness"       Value="0"/>
        <Setter Property="Cursor"                Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        <Setter Property="RenderTransform"       Value="scale(1)"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border x:Name="Root"
                        Background="{TemplateBinding Background}"
                        CornerRadius="10"
                        Padding="{TemplateBinding Padding}"
                        Height="{TemplateBinding Height}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.Secondary:pointerover">
        <Setter Property="RenderTransform" Value="scale(1.04)"/>
    </Style>
    <Style Selector="Button.Secondary:pressed">
        <Setter Property="RenderTransform" Value="scale(0.95)"/>
    </Style>
    <Style Selector="Button.Secondary:pressed /template/ Border#Root">
        <Setter Property="Opacity" Value="0.72"/>
    </Style>
    <Style Selector="Button.Secondary:disabled /template/ Border#Root">
        <Setter Property="Opacity" Value="0.40"/>
    </Style>

    <!-- ═══════════════════════════════════════════════
         GHOST BUTTON
         Height=36, transparent bg, dark separator border,
         scale 1.08 hover / 0.94 press
    ═══════════════════════════════════════════════ -->
    <Style Selector="Button.Ghost">
        <Setter Property="Background"            Value="Transparent"/>
        <Setter Property="Foreground"            Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="FontSize"              Value="13"/>
        <Setter Property="FontWeight"            Value="SemiBold"/>
        <Setter Property="Padding"               Value="14,8"/>
        <Setter Property="Height"                Value="36"/>
        <Setter Property="BorderThickness"       Value="1"/>
        <Setter Property="BorderBrush"           Value="{StaticResource BrushSeparator}"/>
        <Setter Property="Cursor"                Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        <Setter Property="RenderTransform"       Value="scale(1)"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8"
                        Padding="{TemplateBinding Padding}"
                        Height="{TemplateBinding Height}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.Ghost:pointerover">
        <Setter Property="RenderTransform" Value="scale(1.08)"/>
    </Style>
    <Style Selector="Button.Ghost:pressed">
        <Setter Property="RenderTransform" Value="scale(0.94)"/>
    </Style>
    <Style Selector="Button.Ghost:pressed /template/ Border#Bd">
        <Setter Property="Opacity" Value="0.65"/>
    </Style>

    <!-- ═══════════════════════════════════════════════
         DESTRUCTIVE BUTTON
         Height=36, red border, scale 1.08 hover / 0.94 press
    ═══════════════════════════════════════════════ -->
    <Style Selector="Button.Destructive">
        <Setter Property="Background"            Value="{StaticResource BrushDestructiveBg}"/>
        <Setter Property="Foreground"            Value="{StaticResource BrushRed}"/>
        <Setter Property="FontSize"              Value="13"/>
        <Setter Property="Padding"               Value="14,8"/>
        <Setter Property="Height"                Value="36"/>
        <Setter Property="BorderThickness"       Value="1"/>
        <Setter Property="BorderBrush"           Value="{StaticResource BrushDestructiveBorder}"/>
        <Setter Property="Cursor"                Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        <Setter Property="RenderTransform"       Value="scale(1)"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8"
                        Padding="{TemplateBinding Padding}"
                        Height="{TemplateBinding Height}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.Destructive:pointerover">
        <Setter Property="RenderTransform" Value="scale(1.08)"/>
    </Style>
    <Style Selector="Button.Destructive:pointerover /template/ Border#Bd">
        <Setter Property="Background" Value="{StaticResource BrushDestructiveBorder}"/>
    </Style>
    <Style Selector="Button.Destructive:pressed">
        <Setter Property="RenderTransform" Value="scale(0.94)"/>
    </Style>

    <!-- ═══════════════════════════════════════════════
         PILL ACTION BUTTON
         Transparent outer, press scale 0.96, hover opacity 0.82
    ═══════════════════════════════════════════════ -->
    <Style Selector="Button.PillActionBtn">
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="BorderThickness"            Value="0"/>
        <Setter Property="Padding"                    Value="0"/>
        <Setter Property="HorizontalAlignment"        Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="RenderTransformOrigin"      Value="0.5,0.5"/>
        <Setter Property="RenderTransform"            Value="scale(1)"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.10"/>
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <ContentPresenter Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  HorizontalContentAlignment="Stretch"/>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.PillActionBtn:pointerover">
        <Setter Property="Opacity"         Value="0.82"/>
    </Style>
    <Style Selector="Button.PillActionBtn:pressed">
        <Setter Property="RenderTransform" Value="scale(0.96)"/>
        <Setter Property="Opacity"         Value="0.65"/>
    </Style>
    <Style Selector="Button.PillActionBtn:disabled">
        <Setter Property="Opacity" Value="0.40"/>
    </Style>

    <!-- ── Sidebar nav button ── -->
    <Style Selector="Button.NavBtn">
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="Foreground"                 Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="FontSize"                   Value="14"/>
        <Setter Property="FontWeight"                 Value="Medium"/>
        <Setter Property="Padding"                    Value="12,10"/>
        <Setter Property="Margin"                     Value="8,2"/>
        <Setter Property="HorizontalAlignment"        Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="BorderThickness"            Value="0"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="10"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.NavBtn:pointerover">
        <Setter Property="Background" Value="{StaticResource BrushElevated}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
    </Style>
    <Style Selector="Button.NavBtn.Active">
        <Setter Property="Background" Value="{StaticResource BrushAccentSubtle}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
    </Style>
    <Style Selector="Button.NavBtn.Active:pointerover">
        <Setter Property="Background" Value="{StaticResource BrushAccentSubtle}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
    </Style>

    <!-- ── ToggleButton secondary ── -->
    <Style Selector="ToggleButton.Secondary">
        <Setter Property="Background"            Value="{StaticResource BrushElevated}"/>
        <Setter Property="Foreground"            Value="{StaticResource BrushText}"/>
        <Setter Property="FontSize"              Value="13"/>
        <Setter Property="FontWeight"            Value="Medium"/>
        <Setter Property="Padding"               Value="14,8"/>
        <Setter Property="Height"                Value="38"/>
        <Setter Property="BorderThickness"       Value="0"/>
        <Setter Property="Cursor"                Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        <Setter Property="RenderTransform"       Value="scale(1)"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="ToggleButton">
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="10"
                        Padding="{TemplateBinding Padding}"
                        Height="{TemplateBinding Height}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="ToggleButton.Secondary:checked">
        <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ToggleButton.Secondary:pointerover">
        <Setter Property="RenderTransform" Value="scale(1.04)"/>
    </Style>
    <Style Selector="ToggleButton.Secondary:pressed">
        <Setter Property="RenderTransform" Value="scale(0.95)"/>
    </Style>

    <!-- ── Card borders ── -->
    <Style Selector="Border.Card">
        <Setter Property="Background"      Value="{StaticResource BrushCardBg}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrushCardBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="12"/>
        <Setter Property="BoxShadow"       Value="0 4 24 0 #55000000"/>
    </Style>
    <Style Selector="Border.AccentCard">
        <Setter Property="Background"      Value="{StaticResource BrushAccentCardBg}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrushAccentCardBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="14"/>
        <Setter Property="BoxShadow"       Value="0 4 24 0 #55000000"/>
    </Style>

    <!-- ═══════════════════════════════════════════════
         SYNC SLIDER  (Track-free implementation)
         3-column grid: [fill★] [thumb auto] [unfill★]
         Column widths driven from SyncSlider.RefreshFill() in code,
         bypassing all Avalonia 11 Track/TemplateBinding issues.
    ═══════════════════════════════════════════════ -->
    <Style Selector="controls|SyncSlider">
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Cursor"    Value="Hand"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="Slider">
                <Grid MinHeight="34" Background="Transparent">

                    <!-- Full-width dark rail (always visible beneath fill) -->
                    <Border Height="4" CornerRadius="2"
                            Background="{StaticResource BrushElevated}"
                            Opacity="0.7"
                            VerticalAlignment="Center"/>

                    <!-- Three-column track: [fill★] [thumb auto] [unfill★]  -->
                    <Grid x:Name="PART_TrackGrid" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Gradient fill (left of thumb, col 0) -->
                        <Border Grid.Column="0" Height="4" CornerRadius="2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                    <GradientStop Color="#7B5FFF" Offset="0"/>
                                    <GradientStop Color="#2266FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Thumb: 28×30 hit zone with 4×22 white bar (col 1) -->
                        <Grid Grid.Column="1" Width="28" Height="30" Background="Transparent">
                            <Border x:Name="Handle"
                                    Width="4" Height="22"
                                    CornerRadius="2"
                                    Background="White"
                                    BoxShadow="0 0 8 0 #552266FF"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    RenderTransformOrigin="50%,50%"
                                    RenderTransform="scale(1)">
                                <Border.Transitions>
                                    <Transitions>
                                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
                                    </Transitions>
                                </Border.Transitions>
                            </Border>
                        </Grid>

                        <!-- Col 2: empty — dark rail from background layer shows through -->
                    </Grid>

                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Handle scale on hover -->
    <Style Selector="controls|SyncSlider:pointerover /template/ Border#Handle">
        <Setter Property="RenderTransform" Value="scaleX(1.5) scaleY(1.15)"/>
        <Setter Property="BoxShadow"       Value="0 0 14 2 #882266FF"/>
    </Style>
    <!-- Handle scale while pressing/dragging -->
    <Style Selector="controls|SyncSlider:pressed /template/ Border#Handle">
        <Setter Property="RenderTransform" Value="scaleX(1.8) scaleY(1.25)"/>
        <Setter Property="BoxShadow"       Value="0 0 18 4 #AA2266FF"/>
    </Style>

</Styles>
